# ╔══════════════════════════════════════════════════════════╗
# ║  NEXUS SEO — Variables d'environnement                  ║
# ║  Copiez ce fichier en .env.local et remplissez          ║
# ╚══════════════════════════════════════════════════════════╝

# ─── Base de donnees (REQUIS) ──────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/nexus_seo"

# ─── NextAuth (REQUIS) ────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_URL="http://localhost:3000"

# ─── OAuth Providers (OPTIONNEL — pour login social) ──────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── IA & LLMs (OPTIONNEL — enrichit les recommandations) ─
# OpenAI: RAG AI Advisor, sentiment embeddings, contenu structure
OPENAI_API_KEY=""
# Google Gemini: monitoring visibilite IA
GEMINI_API_KEY=""
# Anthropic Claude: monitoring visibilite IA
ANTHROPIC_API_KEY=""

# ─── DataForSEO (OPTIONNEL — donnees keywords reelles) ────
# https://dataforseo.com — ~20$/mois usage modere
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# ─── Google PageSpeed (OPTIONNEL — augmente le quota) ─────
# Sans cle: 25K requetes/jour. Avec cle: illimite
GOOGLE_PAGESPEED_API_KEY=""

# ─── Alertes Email (OPTIONNEL — 3000/mois gratuit) ────────
# https://resend.com
RESEND_API_KEY=""
EMAIL_FROM="Nexus SEO <notifications@nexus.kayzen-lyon.fr>"

# ─── Cache Redis (OPTIONNEL — 10K/jour gratuit) ───────────
# https://upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Alertes Slack (OPTIONNEL) ────────────────────────────
SLACK_WEBHOOK_URL=""

# ─── Webhooks (OPTIONNEL) ─────────────────────────────────
WEBHOOK_URL=""

# ─── Cron Security (RECOMMANDE en production) ─────────────
CRON_SECRET=""

# ─── Application ──────────────────────────────────────────
NODE_ENV="development"
