    "postinstall": "prisma generate",
    "setup": "prisma db push && tsx prisma/seed.ts",
    "setup:full": "npm install && prisma generate && prisma db push && tsx prisma/seed.ts",
    "generate:qr": "tsx scripts/generate-qr.ts"
  },
