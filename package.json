    "framer-motion": "^11.2.0",
    "lucide-react": "^0.383.0",
    "next": "^14.2.35",
    "next-auth": "^4.24.7",
    "next-themes": "^0.3.0",
    "openai": "^4.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
